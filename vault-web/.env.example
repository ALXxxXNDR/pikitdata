# Vercel Dashboard → Settings → Environment Variables 에 채우기.
# 로컬 개발은 .env.local 에 같은 내용 두면 됨.

# Soneium Tenderly RPC (wss 도 OK — 코드에서 https 로 자동 변환)
TENDERLY_RPC_URL=

# 알림 메일 — Resend.com 무료 tier (월 3,000건)
RESEND_API_KEY=
RESEND_FROM=Vault Alert <onboarding@resend.dev>
ALERT_EMAIL_TO=alex@depsell.io

# 임계 알림 쿨다운 (시간) — 같은 지갑 재발송 방지. daily cron 이라 20시간 권장.
ALERT_COOLDOWN_HOURS=20

# ─────────────────────────────────────────────────────────────────
# 사용자 정의 알림 저장 — Vercel Edge Config
# ─────────────────────────────────────────────────────────────────
# 읽기:  EDGE_CONFIG (Vercel Dashboard → Storage → Edge Config → Connect Project 시 자동 set)
# 쓰기:  VERCEL_API_TOKEN (Account Settings → Tokens → Create) + 선택 VERCEL_TEAM_ID
# 미설정 시: wallet detail 의 토글 UI 는 보이지만 저장 안 됨. 정적 fallback.
EDGE_CONFIG=
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=

# Vercel Cron 호출 시 인증 — 안 설정하면 누구나 /api/alert 호출 가능
CRON_SECRET=

# 메일 본문의 대시보드 링크 — Vercel 도메인
NEXT_PUBLIC_BASE_URL=https://your-vault.vercel.app

# ─────────────────────────────────────────────────────────────────
# 인증 (Auth.js + Google OAuth) — 회사 도메인 화이트리스트
# ─────────────────────────────────────────────────────────────────
# JWT 서명 시크릿 (랜덤 32+ 바이트). 로컬에서 생성:
#   openssl rand -base64 32
AUTH_SECRET=

# Google Cloud Console 에서 발급 — 자세한 절차는 README 참고
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 허용할 이메일 도메인 (콤마 구분). 미설정 시 despell.io 만 허용.
AUTH_ALLOWED_DOMAINS=despell.io

# Vercel 배포 시엔 자동 감지되므로 보통 불필요.
# 로컬 dev 면 http://localhost:3000 으로.
# AUTH_URL=

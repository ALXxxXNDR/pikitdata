# Vercel Dashboard → Settings → Environment Variables 에 채우기.
# 로컬 개발은 .env.local 에 같은 내용 두면 됨.

# Soneium Tenderly RPC (wss 도 OK — 코드에서 https 로 자동 변환)
TENDERLY_RPC_URL=

# 알림 메일 — Resend.com 무료 tier (월 3,000건)
RESEND_API_KEY=
RESEND_FROM=Vault Alert <onboarding@resend.dev>
ALERT_EMAIL_TO=alex@depsell.io

# 임계 알림 쿨다운 (시간) — 같은 지갑 재발송 방지
ALERT_COOLDOWN_HOURS=1

# Vercel Cron 호출 시 인증 — 안 설정하면 누구나 /api/alert 호출 가능
CRON_SECRET=

# 메일 본문의 대시보드 링크 — Vercel 도메인
NEXT_PUBLIC_BASE_URL=https://your-vault.vercel.app

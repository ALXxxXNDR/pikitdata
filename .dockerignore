# Synology 빌드 시간 단축 — 불필요한 파일 컨텍스트에서 제외.
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

.git/
.gitignore
.gitattributes

.DS_Store
.idea/
.vscode/

# 데이터는 볼륨 마운트로 제공 — 이미지에 굽지 않음.
data/
"PIKIT BETA DATA/"
*.zip

# 문서/배포 가이드는 빌드에 불필요.
*.md
DEPLOY.md
README.md

# Streamlit secrets 파일 (있으면) 은 절대 이미지에 굽지 않음.
.streamlit/secrets.toml
